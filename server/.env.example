# TheMealDB API base (no trailing slash)
MEALDB_API_BASE=https://www.themealdb.com/api/json/v1

# TheMealDB dev API key. "1" is the public test key documented by TheMealDB.
# Get a paid key at https://www.themealdb.com/api.php for production use.
MEALDB_API_KEY=1

# Port the Express proxy listens on
PORT=5174

# Comma-separated list of allowed CORS origins (client dev server by default)
CLIENT_ORIGIN=http://localhost:5173
